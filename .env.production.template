# ============================================
# BizOS - Production Configuration Template
# ============================================
# CRITICAL: This template contains production settings
# Replace ALL placeholder values before deployment
# Use secrets management system in production
# ============================================

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
# CRITICAL: MUST be false in production
DEV_MODE=false
VITE_DEBUG_MODE=false

# ============================================
# SERVER PORTS
# ============================================
PORT=3000
VOICE_GATEWAY_PORT=3001
API_PREFIX=api

# ============================================
# DATABASE (Production PostgreSQL)
# ============================================
# Use managed database service (AWS RDS, DigitalOcean Managed Database)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://bizos_prod:CHANGE_ME_STRONG_PASSWORD@your-db-host:5432/bizos_production

# Enable SSL/TLS for production database
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Optional: CA certificate path for managed databases
# DATABASE_CA_CERT=/etc/ssl/certs/ca-certificate.crt

# CRITICAL: Generate unique encryption keys
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000
SQLITE_MASTER_KEY=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000
CHANNEL_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000

# ============================================
# REDIS (Production Redis)
# ============================================
# CRITICAL: Must use strong password in production
# Generate: openssl rand -hex 32
# Use managed Redis (AWS ElastiCache, DigitalOcean Managed Redis)
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@your-redis-host:6379
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0

# ============================================
# AUTHENTICATION (Production Keys)
# ============================================
# CRITICAL: Generate new RSA-4096 keypairs for production
# Commands:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 < private.pem | tr -d '\n'
#   base64 < public.pem | tr -d '\n'

RS_PRIVATE_KEY=CHANGE_ME_BASE64_ENCODED_RSA_4096_PRIVATE_KEY
RS_PUBLIC_KEY=CHANGE_ME_BASE64_ENCODED_RSA_4096_PUBLIC_KEY
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Admin JWT (separate keypair)
ADMIN_RS_PRIVATE_KEY=CHANGE_ME_BASE64_ENCODED_ADMIN_RSA_4096_PRIVATE_KEY
ADMIN_RS_PUBLIC_KEY=CHANGE_ME_BASE64_ENCODED_ADMIN_RSA_4096_PUBLIC_KEY

# CSRF Protection
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000

# Internal API Key
API_INTERNAL_KEY=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000

WIDGET_VERIFICATION_TIMEOUT_MINUTES=30

# ============================================
# OAUTH2 (Production Credentials)
# ============================================
# Register production app at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://console.trybizos.com/api/auth/google/callback

# Register production app at: https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-production-microsoft-client-id
MICROSOFT_CLIENT_SECRET=CHANGE_ME_MICROSOFT_CLIENT_SECRET
MICROSOFT_CALLBACK_URL=https://console.trybizos.com/api/auth/microsoft/callback
MICROSOFT_TENANT=common

# ============================================
# PAYMENT (Stripe Production)
# ============================================
# CRITICAL: Use production keys, not test keys
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME_YOUR_LIVE_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME_YOUR_LIVE_WEBHOOK_SECRET
STRIPE_PRICE_ID_STARTER=price_live_starter_plan_id
STRIPE_PRICE_ID_PRO=price_live_pro_plan_id

# ============================================
# MESSAGING PLATFORMS (Production)
# ============================================
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_WHATSAPP_VERIFY_TOKEN
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_WHATSAPP_WEBHOOK_SECRET

META_APP_ID=your-production-meta-app-id
META_APP_SECRET=CHANGE_ME_META_APP_SECRET
FACEBOOK_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_FACEBOOK_VERIFY_TOKEN
FACEBOOK_ACCESS_TOKEN=CHANGE_ME_FACEBOOK_PAGE_ACCESS_TOKEN

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_AUTH_TOKEN
DEFAULT_AREA_CODE=415
WEBHOOK_BASE_URL=https://console.trybizos.com/api

# ============================================
# VOICE SERVICES (Production)
# ============================================
DEEPGRAM_API_KEY=CHANGE_ME_DEEPGRAM_API_KEY
CARTESIA_API_KEY=CHANGE_ME_CARTESIA_API_KEY

VOICE_GATEWAY_WSS_URL=wss://console.trybizos.com
VOICE_GATEWAY_HTTP_URL=https://console.trybizos.com
BACKEND_API_URL=http://backend:3000

# ============================================
# AI / LLM (Production)
# ============================================
# OpenRouter.ai production API key
OPENAI_API_KEY=sk-or-v1-CHANGE_ME_YOUR_PRODUCTION_OPENROUTER_KEY
OPENAI_MODEL=openai/gpt-4o
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME_YOUR_PRODUCTION_OPENROUTER_KEY
OPENAI_TEMPERATURE=0.7

# ============================================
# EMAIL (Production)
# ============================================
# Choose ONE email provider for transactional emails

# Postmark (Recommended)
POSTMARK_SERVER_TOKEN=CHANGE_ME_POSTMARK_SERVER_TOKEN

# OR Amazon SES
# AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
# AWS_REGION=us-east-1

# OR Mailgun
# MAILGUN_API_KEY=CHANGE_ME_MAILGUN_API_KEY
# MAILGUN_DOMAIN=mg.yourdomain.com

# OR SMTP
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=CHANGE_ME_SMTP_USERNAME
# SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# ============================================
# GOOGLE SERVICES (Production)
# ============================================
GOOGLE_PLACES_API_KEY=CHANGE_ME_GOOGLE_PLACES_API_KEY
GOOGLE_GMB_API_KEY=CHANGE_ME_GOOGLE_GMB_API_KEY
GOOGLE_REDIRECT_URI=https://console.trybizos.com/api/integrations/google-calendar/callback

# Google Ads (if using Mark agent)
# GOOGLE_ADS_DEVELOPER_TOKEN=CHANGE_ME_GOOGLE_ADS_DEVELOPER_TOKEN
# GOOGLE_ADS_CLIENT_ID=CHANGE_ME_GOOGLE_ADS_CLIENT_ID
# GOOGLE_ADS_CLIENT_SECRET=CHANGE_ME_GOOGLE_ADS_CLIENT_SECRET
# GOOGLE_ADS_REFRESH_TOKEN=CHANGE_ME_GOOGLE_ADS_REFRESH_TOKEN

# ============================================
# LEAD ENRICHMENT (Production)
# ============================================
HUNTER_API_KEY=CHANGE_ME_HUNTER_API_KEY
CLEARBIT_API_KEY=CHANGE_ME_CLEARBIT_API_KEY

# ============================================
# MONITORING & LOGGING (Production)
# ============================================
# CRITICAL: Configure error tracking for production
SENTRY_DSN=https://CHANGE_ME_YOUR_SENTRY_DSN@sentry.io/project-id

# Production log level (info or warn recommended)
LOG_LEVEL=info

# ============================================
# CORS & FRONTEND (Production)
# ============================================
# CRITICAL: Set to your production domain
CORS_ORIGIN=https://console.trybizos.com
FRONTEND_URL=https://console.trybizos.com

VITE_API_URL=https://console.trybizos.com/api/v1
VITE_WS_URL=wss://console.trybizos.com
VITE_APP_ENV=production

# hCaptcha production site key
# Get from: https://dashboard.hcaptcha.com/
VITE_HCAPTCHA_SITE_KEY=CHANGE_ME_YOUR_PRODUCTION_HCAPTCHA_SITE_KEY

# ============================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================
#
# Before deploying to production:
#
# □ SECURITY
#   □ All CHANGE_ME values replaced with actual credentials
#   □ DEV_MODE set to false
#   □ Strong passwords generated for database and Redis
#   □ Unique encryption keys generated (DB_ENCRYPTION_KEY, etc.)
#   □ Production RSA keypairs generated for JWT
#   □ All secrets stored in secrets management system (not in .env file)
#
# □ DATABASE
#   □ Using managed database service (AWS RDS, DigitalOcean)
#   □ SSL/TLS enabled (DATABASE_SSL=true)
#   □ Database backups configured (automated daily backups)
#   □ Connection pooling configured appropriately
#
# □ REDIS
#   □ Using managed Redis service (AWS ElastiCache, DigitalOcean)
#   □ Password authentication enabled
#   □ Persistence (AOF) enabled
#   □ Redis backups configured
#
# □ AUTHENTICATION
#   □ OAuth2 apps registered with production callback URLs
#   □ Stripe production keys and webhooks configured
#   □ CSRF protection enabled
#   □ Rate limiting configured
#
# □ INTEGRATIONS
#   □ All API keys switched from test/sandbox to production
#   □ Webhook URLs updated to production domain
#   □ Webhook signature verification enabled
#   □ Integration rate limits understood and configured
#
# □ MONITORING
#   □ Sentry configured for error tracking
#   □ Prometheus metrics endpoint secured
#   □ Health check endpoint accessible
#   □ Log aggregation configured (CloudWatch, Datadog, etc.)
#   □ Alerts configured for critical errors
#
# □ INFRASTRUCTURE
#   □ HTTPS/SSL enabled (NGINX + Let's Encrypt)
#   □ Domain DNS configured correctly
#   □ Firewall rules configured (only necessary ports open)
#   □ Docker containers resource limits set
#   □ Container health checks configured
#   □ Backup strategy documented and tested
#
# □ TESTING
#   □ All environment variables validated
#   □ Database migrations run successfully
#   □ Application starts without errors
#   □ Health check returns 200 OK
#   □ OAuth2 login flows tested
#   □ Payment flow tested with real card
#   □ Webhook deliveries tested
#   □ Email sending tested
#
# □ COMPLIANCE
#   □ Privacy policy updated
#   □ Terms of service updated
#   □ GDPR compliance verified
#   □ Data retention policy documented
#   □ Security incident response plan ready
#
# □ DOCUMENTATION
#   □ Deployment runbook created
#   □ Rollback procedure documented
#   □ Secret rotation process documented
#   □ Incident response contacts listed
#   □ Architecture diagram updated
#
# ============================================
# SECRET ROTATION SCHEDULE
# ============================================
#
# Rotate these secrets every 90 days:
# - DB_ENCRYPTION_KEY
# - CHANNEL_ENCRYPTION_KEY
# - API_INTERNAL_KEY
# - CSRF_SECRET
# - REDIS_PASSWORD
# - Database password
#
# Rotate these on security incident:
# - JWT RSA keypairs
# - API keys (OpenRouter, Stripe, Twilio, etc.)
# - OAuth2 client secrets
#
# Monitor for expiration:
# - SSL/TLS certificates (Let's Encrypt auto-renews)
# - OAuth2 access tokens (auto-refresh)
# - API keys (check provider dashboard)
#
# ============================================
